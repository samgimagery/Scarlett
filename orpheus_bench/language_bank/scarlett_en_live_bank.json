{
  "name": "Scarlett English Live Voice Language Bank",
  "version": "2026-05-03-q4-v1",
  "req": "REQ-108",
  "locale": "en",
  "voice_target": "leah",
  "model_target": "legraphista/Orpheus:latest",
  "model_note": "Approved Q4_K_M English path. Speed wins over small clarity delta.",
  "design_principles": [
    "Silence is better under roughly 500ms unless the user needs reassurance.",
    "Tiny fillers and repair lines should be cached, not generated live.",
    "Every line must be truthful to system state: do not imply lookup if no lookup is happening.",
    "Emotion is gated; chuckles are rare, reviewed, and never default.",
    "Lines should be interruptible and easy to cancel mid-playback.",
    "Rotate by intent, latency window, confidence, and recent line history to avoid sounding canned.",
    "French / FR-CA requires later localization, not direct translation."
  ],
  "routing_dimensions": {
    "line_type": ["silence", "backchannel", "receipt", "floor_holder", "retrieval_progress", "answer_bridge", "repair", "uncertainty", "empathy", "boundary", "handoff", "interruption", "rare_emotion"],
    "latency_window": ["none", "under_500ms", "500_1200ms", "800_2500ms", "over_2500ms"],
    "confidence": ["unknown", "high", "medium", "low", "conflict"],
    "affect": ["neutral", "warm", "busy", "confused", "frustrated", "upset", "casual"],
    "interruptible": [true, false],
    "cache_priority": ["critical", "high", "medium", "low", "do_not_cache"]
  },
  "selection_rules": [
    {
      "id": "rule_silence_short_pause",
      "if": {"user_state": "paused", "pause_ms_lt": 500},
      "then": {"line_type": "silence"},
      "why": "Avoid anxious over-talking."
    },
    {
      "id": "rule_soft_continue",
      "if": {"user_state": "likely_continuing", "pause_ms_between": [500, 1200]},
      "then": {"line_type": "backchannel", "max_duration_ms": 700},
      "why": "Signal attention without taking the floor."
    },
    {
      "id": "rule_fast_retrieval",
      "if": {"user_state": "finished", "retrieval_eta_ms_lt": 800},
      "then": {"line_type": "silence_or_receipt"},
      "why": "Do not waste time with filler if answer is about to arrive."
    },
    {
      "id": "rule_normal_retrieval",
      "if": {"user_state": "finished", "retrieval_eta_ms_between": [800, 2500]},
      "then": {"line_type": "floor_holder", "cache_priority": "critical"},
      "why": "Claim turn and make lookup feel intentional."
    },
    {
      "id": "rule_slow_retrieval",
      "if": {"retrieval_eta_ms_gt": 2500},
      "then": {"line_type": "retrieval_progress", "repeat_guard_s": 12},
      "why": "Give progress sparingly, not a loop."
    },
    {
      "id": "rule_high_confidence",
      "if": {"answer_ready": true, "confidence": "high"},
      "then": {"line_type": "answer", "avoid_filler": true},
      "why": "Answer directly when ready."
    },
    {
      "id": "rule_low_confidence",
      "if": {"confidence": "low"},
      "then": {"line_type": "uncertainty_or_repair"},
      "why": "Do not turn uncertainty into confident speech."
    },
    {
      "id": "rule_user_interrupts",
      "if": {"user_state": "interrupting_scarlett"},
      "then": {"action": "cancel_playback", "line_type": "interruption", "optional": true},
      "why": "Barge-in must feel instant."
    },
    {
      "id": "rule_chuckle_gate",
      "if": {"line_type": "rare_emotion"},
      "then": {"requires": ["manual_reviewed", "user_casual_or_warm", "not_first_latency_line"], "max_frequency": "rare"},
      "why": "Alive, not theatrical."
    }
  ],
